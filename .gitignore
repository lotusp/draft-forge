# ── Input CAD models — NEVER commit (proprietary / confidential) ──
parts/
parts_real/
*.step
*.stp
*.STEP
*.STP
*.brep

# ── ECAD 输入（Pick&Place / Gerber）—— 同 CAD 模型，外部提供，不进工程 ──
#    示例数据见 ../ecad_proto/data/（MosaicBus，MIT）；运行时经网页上传
*.gbr
*.gtp
*.gm1
*.gko

# ── Generated output — reproducible, not source ──
# web app conversion results (meta.json + drawings + glTF)
results/
# CLI output dirs
out/
out_*/

# Loose generated drawings anywhere...
*.svg
*.dxf
*.glb
# ...but keep the bundled front-end assets (three.js etc.)
!web/static/
!web/static/**

# ── Python ──
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── 样例测试数据 —— 例外：这些要入库，让 clone 后能直接验证 ──
#    仅限公开数据集(NIST 公有领域 / MosaicBus MIT)与虚构样例，
#    入库前经敏感信息扫描（企业名/水印/真实图号/导出路径），零命中。
#    ⚠️ 客户提供的模型图纸一律不得放进来。
!samples/
!samples/**

# ── OS / editor ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
